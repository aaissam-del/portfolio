---
/**
 * Hero section with animated name treatment, availability badge, key links and profile portrait.
 */
import Icon from './Icon.astro';
import { heroStats, profile, socialLinks } from '../data/profile';
---
<section class="section hero" id="top">
  <div class="container hero__grid">
    <div class="hero__content" data-reveal>
      <p class="section-kicker">Portfolio personnel</p>
      <h1 class="hero__title">
        <span class="hero__title-gradient">{profile.fullName}</span>
      </h1>
      <p
        class="hero__subtitle hero__subtitle-typing"
        data-typing-text="Portfolio personnel, presence publique et points de contact reunis dans une interface claire et evolutive."
        aria-label="Portfolio personnel, presence publique et points de contact reunis dans une interface claire et evolutive."
      >
        <span data-typing-output>Portfolio personnel, presence publique et points de contact reunis dans une interface claire et evolutive.</span>
      </p>

      <div class="hero__badge">
        <span class="hero__badge-dot"></span>
        <span>{profile.availability}</span>
      </div>

      <div class="hero__actions">
        <a class="button button--primary" href="#contact">
          <Icon name="send" />
          <span>Me Contacter</span>
        </a>
        <a class="button button--ghost" href="https://github.com/aaissam-del" target="_blank" rel="noreferrer">
          <Icon name="github" />
          <span>Voir GitHub</span>
        </a>
      </div>

      <div class="hero__socials">
        {socialLinks.map((link) => (
          <a class="hero__pill" href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noreferrer' : undefined}>
            <Icon name={link.icon} class="hero__pill-icon" />
            <span>{link.label}</span>
          </a>
        ))}
      </div>

      {heroStats.length > 0 && (
        <div class="hero__stats">
          {heroStats.map((stat) => (
            <article class="hero__stat">
              <strong>{stat.value}</strong>
              <span>{stat.label}</span>
            </article>
          ))}
        </div>
      )}
    </div>

    <div class="hero__media" data-reveal>
      <div class="hero__portrait-shell">
        <div class="hero__portrait-ring"></div>
        <img class="hero__portrait" src={profile.avatarUrl} alt={`Portrait de ${profile.fullName}`} loading="eager" />
      </div>
      <p class="hero__caption">{profile.title}</p>
    </div>
  </div>

  <div class="hero__scroll-indicator" aria-hidden="true">
    <span></span>
    <small>Scroll</small>
  </div>

  <script>
    (() => {
      const root = document.querySelector('.hero__subtitle-typing');
      if (!root) return;

      const output = root.querySelector('[data-typing-output]');
      const fullText = root.getAttribute('data-typing-text') || 'Portfolio personnel';
      if (!output || !fullText) return;

      const wait = (ms) => new Promise((resolve) => window.setTimeout(resolve, ms));

      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduceMotion) {
        output.textContent = fullText;
        return;
      }

      (async () => {
        root.dataset.phase = 'typing';
        output.textContent = '';
        await wait(250);

        for (let index = 1; index <= fullText.length && root.isConnected; index += 1) {
          output.textContent = fullText.slice(0, index);
          await wait(92);
        }

        if (!root.isConnected) return;

        root.dataset.phase = 'done';
        output.textContent = fullText;
      })();
    })();
  </script>

  <style>
    .hero__subtitle-typing {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      min-height: 3.6rem;
      white-space: normal;
      width: min(100%, 56ch);
    }

    @media (max-width: 767px) {
      .hero__subtitle-typing {
        min-height: 4.8rem;
      }
    }

    .hero__subtitle-typing::after {
      content: '';
      display: none;
    }
  </style>
</section>
