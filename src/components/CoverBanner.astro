---
/**
 * AI-themed cover banner with stylized robot illustration
 */
---

<section class="cover-banner" aria-label="AI Portfolio Cover">
  <div class="cover-banner__background">
    <svg class="cover-banner__illustration" viewBox="0 0 1200 400" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
      <!-- Background gradient elements -->
      <defs>
        <linearGradient id="botGradient" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#ff4d4d;stop-opacity:0.15" />
          <stop offset="100%" style="stop-color:#ff8a3d;stop-opacity:0.1" />
        </linearGradient>
        <filter id="glow">
          <feGaussianBlur stdDeviation="4" result="coloredBlur" />
          <feMerge>
            <feMergeNode in="coloredBlur" />
            <feMergeNode in="SourceGraphic" />
          </feMerge>
        </filter>
      </defs>

      <!-- Animated background circles -->
      <circle cx="150" cy="100" r="80" fill="url(#botGradient)" opacity="0.6" class="circle-float" />
      <circle cx="1030" cy="300" r="120" fill="url(#botGradient)" opacity="0.4" class="circle-float" style="animation-delay: -1s;" />
      <circle cx="600" cy="150" r="74" fill="rgba(255,77,77,0.18)" class="robot-halo" />
      
      <!-- Robot Head -->
      <g transform="translate(600, 150)" filter="url(#glow)">
        <!-- Head Shell -->
        <rect x="-45" y="-50" width="90" height="95" rx="15" fill="rgba(255,77,77,0.15)" stroke="rgba(255,77,77,0.4)" stroke-width="2" />
        
        <!-- Top Antenna Left -->
        <line x1="-35" y1="-55" x2="-40" y2="-85" stroke="rgba(255,138,61,0.6)" stroke-width="3" stroke-linecap="round" class="antenna-wave" />
        <circle cx="-40" cy="-88" r="4" fill="rgba(255,138,61,0.8)" class="antenna-pulse" />
        
        <!-- Top Antenna Right -->
        <line x1="35" y1="-55" x2="40" y2="-85" stroke="rgba(255,138,61,0.6)" stroke-width="3" stroke-linecap="round" class="antenna-wave" style="animation-delay: -0.3s;" />
        <circle cx="40" cy="-88" r="4" fill="rgba(255,138,61,0.8)" class="antenna-pulse" style="animation-delay: -0.3s;" />
        
        <!-- Left Eye -->
        <circle cx="-20" cy="-20" r="12" fill="rgba(239,68,68,0.2)" stroke="rgba(255,77,77,0.5)" stroke-width="2" />
        <circle cx="-20" cy="-20" r="6" fill="rgba(255,77,77,0.8)" class="eye-blink" />
        
        <!-- Right Eye -->
        <circle cx="20" cy="-20" r="12" fill="rgba(239,68,68,0.2)" stroke="rgba(255,77,77,0.5)" stroke-width="2" />
        <circle cx="20" cy="-20" r="6" fill="rgba(255,77,77,0.8)" class="eye-blink" style="animation-delay: -0.2s;" />
        
        <!-- Mouth -->
        <path d="M -15 15 Q 0 25 15 15" stroke="rgba(255,138,61,0.6)" stroke-width="2" fill="none" stroke-linecap="round" />
      </g>

      <!-- Body -->
      <g transform="translate(600, 270)">
        <rect x="-40" y="0" width="80" height="80" rx="12" fill="rgba(127,29,29,0.15)" stroke="rgba(255,77,77,0.3)" stroke-width="2" />
        
        <!-- Chest Panel -->
        <rect x="-25" y="15" width="50" height="50" rx="8" fill="rgba(255,77,77,0.08)" stroke="rgba(255,138,61,0.3)" stroke-width="1.5" />
        
        <!-- Left Arm -->
        <rect x="-60" y="10" width="18" height="50" rx="9" fill="rgba(239,68,68,0.12)" stroke="rgba(255,77,77,0.3)" stroke-width="1.5" class="arm-swing" />
        
        <!-- Right Arm -->
        <rect x="42" y="10" width="18" height="50" rx="9" fill="rgba(239,68,68,0.12)" stroke="rgba(255,77,77,0.3)" stroke-width="1.5" class="arm-swing" style="animation-delay: -0.4s;" />
        
        <!-- Core Light -->
        <circle cx="0" cy="40" r="8" fill="rgba(255,77,77,0.4)" class="core-pulse" />
      </g>

      <!-- Flying Data Particles -->
      <g class="particle particle-1">
        <circle cx="300" cy="150" r="3" fill="rgba(255,138,61,0.6)" />
      </g>
      <g class="particle particle-2">
        <circle cx="950" cy="200" r="2.5" fill="rgba(255,77,77,0.5)" style="animation-delay: -0.8s;" />
      </g>
      <g class="particle particle-3">
        <circle cx="400" cy="300" r="2" fill="rgba(255,138,61,0.4)" style="animation-delay: -1.2s;" />
      </g>
      <g class="particle particle-4">
        <circle cx="850" cy="80" r="3" fill="rgba(255,77,77,0.4)" style="animation-delay: -0.5s;" />
      </g>
    </svg>
  </div>
  <span class="cover-banner__ambient cover-banner__ambient--one" aria-hidden="true"></span>
  <span class="cover-banner__ambient cover-banner__ambient--two" aria-hidden="true"></span>

  <div class="cover-banner__content">
    <h2 class="cover-banner__title">Bienvenue sur mon Portfolio</h2>
    <p class="cover-banner__subtitle">Découvrez mon univers de développeur & design assisté par l'IA</p>
  </div>

  <style define:vars={{}}>
    .cover-banner {
      position: relative;
      min-height: clamp(20rem, 34vw, 24rem);
      overflow: hidden;
      margin-top: -6.4rem;
      border-radius: 32px;
      background: linear-gradient(135deg, rgba(5,5,5,0.4) 0%, rgba(20,20,20,0.6) 50%, rgba(5,5,5,0.4) 100%);
      isolation: isolate;
    }

    .cover-banner::after {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: linear-gradient(to bottom, rgba(255, 255, 255, 0.035), transparent 32%, transparent 72%, rgba(255, 138, 61, 0.06));
      mix-blend-mode: screen;
      opacity: 0.34;
      z-index: 2;
    }

    .cover-banner__background {
      position: absolute;
      inset: 0;
      overflow: hidden;
      display: grid;
      place-items: center;
    }

    .cover-banner__illustration {
      width: min(100%, 72rem);
      height: 100%;
      opacity: 0.94;
      transform: translateY(3%);
      pointer-events: none;
    }

    .cover-banner__content {
      position: relative;
      z-index: 12;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100%;
      text-align: center;
      padding: 2rem;
      transform: translateY(30%);
    }

    .cover-banner__ambient {
      position: absolute;
      border-radius: 50%;
      filter: blur(34px);
      pointer-events: none;
      z-index: 1;
      animation: ambientDrift 10s ease-in-out infinite;
    }

    .cover-banner__ambient--one {
      width: 20rem;
      height: 20rem;
      top: -6rem;
      left: -3rem;
      background: radial-gradient(circle, rgba(255, 77, 77, 0.16), rgba(255, 77, 77, 0));
    }

    .cover-banner__ambient--two {
      width: 16rem;
      height: 16rem;
      right: -2rem;
      bottom: -5rem;
      background: radial-gradient(circle, rgba(255, 138, 61, 0.14), rgba(255, 138, 61, 0));
      animation-delay: -4.5s;
    }

    .cover-banner__title {
      margin: 0;
      font-size: clamp(2.6rem, 7vw, 5rem);
      font-weight: 700;
      letter-spacing: 0.03em;
      text-transform: none;
      line-height: 0.95;
      background: linear-gradient(120deg, #ffe3e3 0%, #ff9d9d 30%, #ffbe8a 56%, #ff8e8e 82%, #ffe3e3 100%);
      background-size: 220% 100%;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      text-shadow: 0 8px 22px rgba(0, 0, 0, 0.34), 0 0 18px rgba(255, 138, 61, 0.14);
      filter: drop-shadow(0 0 6px rgba(255, 138, 61, 0.14));
      animation: titleShimmer 10s linear infinite;
      margin-bottom: 0.5rem;
    }

    .cover-banner__subtitle {
      margin: 0;
      font-size: clamp(1rem, 2.25vw, 1.25rem);
      color: rgba(245, 245, 245, 0.75);
      font-weight: 500;
      max-width: 500px;
    }

    /* SVG Animations */
    @keyframes antenna-wave {
      0%, 100% { transform: rotate(0deg); transform-origin: 0 0; }
      25% { transform: rotate(15deg); transform-origin: 0 0; }
      75% { transform: rotate(-15deg); transform-origin: 0 0; }
    }

    @keyframes antenna-pulse {
      0%, 100% { opacity: 1; r: 4px; }
      50% { opacity: 0.5; r: 6px; }
    }

    @keyframes eye-blink {
      0%, 80%, 100% { ry: 6px; }
      85%, 95% { ry: 1px; }
    }

    @keyframes arm-swing {
      0%, 100% { transform: rotate(-20deg); transform-origin: -40px 10px; }
      50% { transform: rotate(25deg); transform-origin: -40px 10px; }
    }

    @keyframes core-pulse {
      0%, 100% { r: 8px; opacity: 0.6; }
      50% { r: 12px; opacity: 0.3; }
    }

    @keyframes float {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-30px); }
    }

    @keyframes particle-float {
      0% { opacity: 0; transform: translateY(20px); }
      10% { opacity: 1; }
      90% { opacity: 1; }
      100% { opacity: 0; transform: translateY(-100px); }
    }

    @keyframes titleShimmer {
      from { background-position: 0% 50%; }
      to { background-position: 220% 50%; }
    }

    .circle-float {
      animation: float 6s ease-in-out infinite;
    }

    .robot-halo {
      animation: haloPulse 2.8s ease-in-out infinite;
    }

    .particle {
      animation: particle-float 4s ease-in infinite;
    }

    .antenna-wave {
      transform-box: fill-box;
      transform-origin: center;
      animation: antenna-wave 2s ease-in-out infinite;
    }

    .antenna-pulse {
      animation: antenna-pulse 1.5s ease-in-out infinite;
    }

    .eye-blink {
      animation: eye-blink 3s ease-in-out infinite;
    }

    .arm-swing {
      transform-box: fill-box;
      transform-origin: center;
      animation: arm-swing 2s ease-in-out infinite;
    }

    .core-pulse {
      animation: core-pulse 2s ease-in-out infinite;
    }

    @keyframes haloPulse {
      0%, 100% { opacity: 0.2; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(1.14); }
    }

    @keyframes ambientDrift {
      0%, 100% { transform: translate3d(0, 0, 0); }
      50% { transform: translate3d(0, -12px, 0); }
    }

    @media (max-width: 767px) {
      .cover-banner {
        min-height: 18rem;
        margin-top: -5.5rem;
      }

      .cover-banner__title {
        font-size: clamp(2.1rem, 11vw, 2.9rem);
        letter-spacing: 0.02em;
      }

      .cover-banner__subtitle {
        font-size: 0.95rem;
      }

      .cover-banner__illustration {
        width: min(140%, 58rem);
        opacity: 0.78;
        transform: translateY(6%);
      }

      .cover-banner__content {
        transform: translateY(20%);
      }
    }
  </style>
</section>
